generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      String   @default("FIELD_AGENT")
  branch    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant: FIELD_AGENT belongs to an ADMIN
  adminId String?
  admin   User?   @relation("AgentAdmin", fields: [adminId], references: [id])
  agents  User[]  @relation("AgentAdmin")

  assignedCases     VerificationCase[] @relation("AgentCases")
  createdCustomers  Customer[]
  createdCases      VerificationCase[] @relation("AdminCases")
  rides             AgentRide[]        @relation("AgentRides")
}

model Customer {
  id            String   @id @default(uuid())
  applicationId String   @unique
  firstName     String
  lastName      String
  phone         String?
  email         String?
  address       String
  loanType      String   @default("Home Loan")
  loanAmount    Float
  businessName  String?
  branch        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Multi-tenant: which admin created this customer
  adminId String?
  admin   User?   @relation(fields: [adminId], references: [id])

  verificationCases VerificationCase[]
}

model VerificationCase {
  id     String  @id @default(uuid())
  status String  @default("PENDING")
  type   String
  branch String?

  // Relations
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  agentId String?
  agent   User?   @relation("AgentCases", fields: [agentId], references: [id])

  // Multi-tenant: which admin owns this case
  adminId String?
  admin   User?   @relation("AdminCases", fields: [adminId], references: [id])

  // Data filled by agent
  gpsLatitude  Float?
  gpsLongitude Float?
  remarks      String?

  // Profile data (JSON stored as Text for flexibility)
  profileData String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  media Media[]
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  city      String
  manager   String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-tenant: which admin owns this branch
  adminId String?
}

model Report {
  id          String   @id @default(uuid())
  name        String
  type        String
  generatedBy String
  generatedAt String
  size        String
  dateRange   String?
  format      String?
  createdAt   DateTime @default(now())
  adminId     String?
}

model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String
  entity    String
  timestamp String
  ip        String
  createdAt DateTime @default(now())
  adminId   String?
}

model SystemSetting {
  id                 String   @id @default(uuid())
  orgName            String
  adminEmail         String
  slaDays            Int
  emailOverdue       Boolean  @default(true)
  emailDigest        Boolean  @default(true)
  notifyNewUpload    Boolean  @default(false)
  notifyCaseComplete Boolean  @default(false)
  updatedAt          DateTime @updatedAt
  adminId            String?  @unique
}

model UploadBatch {
  id        String   @id @default(uuid())
  fileName  String
  totalRows Int
  validRows Int
  errorRows Int
  status    String
  createdBy String
  createdAt DateTime @default(now())
  adminId   String?
}

model Media {
  id                 String           @id @default(uuid())
  url                String
  publicId           String
  type               String

  verificationCaseId String
  verificationCase   VerificationCase @relation(fields: [verificationCaseId], references: [id])

  createdAt DateTime @default(now())
}

model AgentRide {
  id            String          @id @default(uuid())
  agentId       String
  agent         User            @relation("AgentRides", fields: [agentId], references: [id], onDelete: Cascade)
  adminId       String
  startTime     DateTime        @default(now())
  endTime       DateTime?
  status        String          @default("STARTED") // STARTED, COMPLETED
  totalDistance Float           @default(0)         // Accumulated distance in kilometers
  locations     AgentLocation[] @relation("RideLocations")

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model AgentLocation {
  id        String    @id @default(uuid())
  rideId    String
  ride      AgentRide @relation("RideLocations", fields: [rideId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  speed     Float?
  timestamp DateTime  @default(now())
}
